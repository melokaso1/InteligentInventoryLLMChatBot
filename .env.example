# El Plonsazo — desarrollo local (valores seguros para taller académico)
# Copia no necesaria si ya existe .env en el repositorio.

DOTNET_API_URL=http://localhost:5151
# Si usas ngrok hacia la API .NET, el chatbot envía ngrok-skip-browser-warning automáticamente:
# DOTNET_API_URL=https://abc123.ngrok-free.app
CHATBOT_API_KEY=elplonsazo-chatbot-dev-key

# Opcional: respuestas conversacionales con OpenAI (sin clave, el chat usa solo reglas LangGraph)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60
OPENAI_HISTORY_LIMIT=10